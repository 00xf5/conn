<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>WorthyJoin — Host agent</title>
  <style>
__CSS__
  </style>
</head>
<body>
  <div class="app">
    <header class="top">
      <div class="brand">
        <span class="mark" aria-hidden="true"></span>
        <div class="brand-text">
          <strong>WorthyJoin</strong>
        </div>
      </div>
      <div class="top-right">
        <span class="pill">Host</span>
        <span class="online-dot" title="Agent online"></span>
        <button type="button" class="icon-btn" id="btn-hide" title="Hide to tray">─</button>
      </div>
    </header>

    <!-- HOME -->
    <main class="view view-home" id="view-home">
      <div class="home-hero">
        <p class="eyebrow">Remote session</p>
        <h1>Ready when you are</h1>
        <p class="lede">Start a multi-agent meeting room. Video tiles below are a UI preview — live streams wire in later.</p>
        <button type="button" class="cta" id="btn-connect">Connect to other agents</button>
        <div class="home-meta">
          <div><span>Server</span><strong>worthyjoin.online</strong></div>
          <div><span>This PC</span><strong id="host-name">—</strong></div>
          <div><span>Mode</span><strong>Preview</strong></div>
        </div>
      </div>
    </main>

    <!-- MEETING (Zoom-style mock) -->
    <main class="view view-meet" id="view-meet" hidden>
      <div class="meet-bar">
        <div class="meet-bar-left">
          <button type="button" class="text-btn" id="btn-leave-top">← Leave</button>
          <span class="meet-title">Agent room · <em>mock</em></span>
        </div>
        <div class="meet-bar-right">
          <span class="meet-timer" id="meet-timer">00:00</span>
          <button type="button" class="chip-btn" data-stub="participants">6 participants</button>
          <button type="button" class="chip-btn" data-stub="invite">Invite</button>
        </div>
      </div>

      <div class="grid" id="tile-grid" aria-label="Meeting tiles">
        <article class="tile self">
          <div class="tile-bg t0"></div>
          <div class="tile-avatar">You</div>
          <div class="tile-foot">
            <span class="tile-name">You · This PC</span>
            <span class="tile-mic on" title="Mic on">🎙</span>
          </div>
        </article>
        <article class="tile">
          <div class="tile-bg t1"></div>
          <div class="tile-avatar">AK</div>
          <div class="tile-foot">
            <span class="tile-name">Alex Kim</span>
            <span class="tile-mic" title="Muted">🔇</span>
          </div>
        </article>
        <article class="tile">
          <div class="tile-bg t2"></div>
          <div class="tile-avatar">MR</div>
          <div class="tile-foot">
            <span class="tile-name">Maya R.</span>
            <span class="tile-mic on">🎙</span>
          </div>
        </article>
        <article class="tile">
          <div class="tile-bg t3"></div>
          <div class="tile-avatar">JT</div>
          <div class="tile-foot">
            <span class="tile-name">Jordan T.</span>
            <span class="tile-mic">🔇</span>
          </div>
        </article>
        <article class="tile">
          <div class="tile-bg t4"></div>
          <div class="tile-avatar">SL</div>
          <div class="tile-foot">
            <span class="tile-name">Sam Lee</span>
            <span class="tile-mic on">🎙</span>
          </div>
        </article>
        <article class="tile">
          <div class="tile-bg t5"></div>
          <div class="tile-avatar">NP</div>
          <div class="tile-foot">
            <span class="tile-name">Nora P.</span>
            <span class="tile-mic">🔇</span>
          </div>
        </article>
      </div>

      <footer class="controls">
        <div class="controls-cluster">
          <button type="button" class="ctrl" id="btn-mute" title="Mute"><span class="ctrl-ico">🎙</span><span>Mute</span></button>
          <button type="button" class="ctrl" id="btn-cam" title="Stop video"><span class="ctrl-ico">📷</span><span>Stop video</span></button>
          <button type="button" class="ctrl" data-stub="share"><span class="ctrl-ico">▣</span><span>Share</span></button>
          <button type="button" class="ctrl" data-stub="chat"><span class="ctrl-ico">💬</span><span>Chat</span></button>
          <button type="button" class="ctrl" data-stub="react"><span class="ctrl-ico">☺</span><span>React</span></button>
        </div>
        <button type="button" class="ctrl leave" id="btn-leave">Leave</button>
      </footer>
    </main>
  </div>
  <div id="toast" class="toast" hidden></div>
  <script>
__JS__
  </script>
</body>
</html>
